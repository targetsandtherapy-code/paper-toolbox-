# 知网：启动时写入 cnki_cookies.txt（见 app.py）；失效时凭下面账号自动登录刷新（见 modules/reference/searcher/cnki.py）
# Cookie 可为空，仅填账号密码亦可由程序登录后生成
CNKI_COOKIES = ""
